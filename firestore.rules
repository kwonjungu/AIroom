// 백암초 급식일지 시스템 Firestore 보안규칙
// Firebase 콘솔 → Firestore Database → 규칙 탭에 이 내용 전체를 붙여넣고 "게시"
//
// ┌─ 주의 ─────────────────────────────────────────┐
// │ Firebase Auth를 쓰지 않으므로 rules로 강제할 수   │
// │ 있는 것은 제한적임 (학교 33명 내부용 전제).     │
// │ 핵심 보호: "결재완료(approved) 일지는 누구도    │
// │ 수정·삭제 불가", "부장 PIN/담당자 PW 재작성 금지"│
// └────────────────────────────────────────────────┘

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── 담당자 계정 ───
    // 최초 1회 생성만 허용. 이후 pwHash 덮어쓰기 금지 (분실 시 관리자가 콘솔에서 삭제)
    match /bap_users/{name} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['pwHash','createdAt'])
                 && request.resource.data.pwHash is string
                 && request.resource.data.pwHash.size() > 20;
      allow update: if false;
      allow delete: if false;
    }

    // ─── 부장 설정 ───
    // 최초 1회만 PIN 설정 가능. 이후 수정 금지 (분실 시 콘솔에서 삭제)
    match /bap_config/boss {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['pinHash','bossName'])
                 && request.resource.data.pinHash is string;
      allow update: if false;
      allow delete: if false;
    }

    // ─── 식단표지 메뉴 ───
    // Auth가 없어 부장만 쓰도록 rules로 강제 불가 (내부 보안은 PIN으로 제어)
    match /bap_menus/{date} {
      allow read: if true;
      allow write: if date.matches('\\d{4}-\\d{2}-\\d{2}');
    }

    // ─── 급식일지 ───
    // 핵심: approved 상태 일지는 수정·삭제 절대 불가
    // submitted 상태에서만 approved로 전환 허용
    match /bap_journals/{date} {
      // list 쿼리 호환을 위해 read는 전면 허용 (내부 보안은 PIN으로 제어)
      allow read: if true;

      // 신규 생성: status=submitted, managerName 필수
      allow create: if request.resource.data.status == 'submitted'
                 && request.resource.data.managerName is string
                 && request.resource.data.managerName.size() > 0
                 && date.matches('\\d{4}-\\d{2}-\\d{2}');

      // 수정 규칙
      allow update: if
        // 1) 기존이 approved면 어떤 수정도 금지
        resource.data.status != 'approved' && (
          // 2-a) 담당자 재제출: submitted → submitted (managerName 동일 유지)
          (request.resource.data.status == 'submitted'
           && request.resource.data.managerName == resource.data.managerName)
          ||
          // 2-b) 결재 승인: submitted → approved
          (resource.data.status == 'submitted'
           && request.resource.data.status == 'approved'
           && request.resource.data.managerName == resource.data.managerName
           && request.resource.data.bossName is string)
        );

      // 삭제 금지 (감사 목적)
      allow delete: if false;
    }
  }
}
